      '    ',
      '    print(f"\\n" + "="*60)',
      '    print(f"FINAL POPULATION: 50 RULES (10 PER COHORT)")',
      '    print("="*60)',
      '    ',
      '    # Show top 3 per cohort (what will be used for matching)',
      '    for cohort_idx in range(5):',
      '        cohort_rules = [r for r in population if r.get("cohort") == cohort_idx + 1]',
      '        cohort_rules.sort(key=lambda r: r.get("score", 0), reverse=True)',
      '        print(f"\\nCohort {cohort_idx + 1} (Top 3 for matching):")',
      '        for i, rule in enumerate(cohort_rules[:3], 1):',
      '            print(f"  {i}. {rule[\'name\']}: score={rule.get(\'score\', 0):.1f} matches")',
      '    ',
      '    print("\\n" + "="*60)',
      '    print("ALL 50 rules saved to BlockingRules sheet")',
      '    print("Top 3 from each cohort (15 total) will be used for matching")',
      '    print("="*60)',
      '    ',
      '    return population  # Return all 50',
      '',
      'def condense_exact_matches(donors):',
      '    """Condense exact name+address duplicates to reduce dataset size."""',
      '    # Build exact match key',
      '    exact_map = {}',
      '    uf_parent = {}',
      '    uf_rank = {}',
      '    ',
      '    def uf_find(x):',
      '        if x not in uf_parent:',
      '            uf_parent[x] = x',
      '            uf_rank[x] = 0',
      '        if uf_parent[x] != x:',
      '            uf_parent[x] = uf_find(uf_parent[x])',
      '        return uf_parent[x]',
      '    ',
      '    def uf_union(x, y):',
      '        px, py = uf_find(x), uf_find(y)',
      '        if px == py: return',
      '        if uf_rank[px] < uf_rank[py]:',
      '            uf_parent[px] = py',
      '        elif uf_rank[px] > uf_rank[py]:',
      '            uf_parent[py] = px',
      '        else:',
      '            uf_parent[py] = px',
      '            uf_rank[px] += 1',
      '    ',
      '    for idx, donor in enumerate(donors):',
      '        first = (donor.get("DonorFirst") or "").strip().upper()',
      '        last = (donor.get("DonorLast") or "").strip().upper()',
      '        addr = (donor.get("Address1") or "").strip().upper()',
      '        city = (donor.get("City") or "").strip().upper()',
      '        state = (donor.get("State") or "").strip().upper()',
      '        zip_code = (donor.get("Zip") or "").strip()',
      '        ',
      '        if first and last and addr:',
      '            key = (first, last, addr, city, state, zip_code)',
      '            if key in exact_map:',
      '                uf_union(idx, exact_map[key])',
      '            else:',
      '                exact_map[key] = idx',
      '    ',
      '    # Keep one representative per group',
      '    representatives = {}',
      '    for idx in range(len(donors)):',
      '        root = uf_find(idx)',
      '        if root not in representatives:',
      '            representatives[root] = donors[idx]',
      '    ',
      '    return list(representatives.values()), uf_parent',
      '',
      'def generate_initial_rule_population_cohorts():',
      '    """Generate 50 diverse initial blocking rules with cohort tags."""',
      '    rules = []',
      '    ',
      '    # Single-field rules (20 rules)',
      '    single_configs = [',
      '        ("DonorLast", ["soundex", "first_3", "first_4", "exact"]),',
      '        ("DonorFirst", ["soundex", "first_3", "first_4"]),',
      '        ("Zip", ["zip5", "zip3"]),',
      '        ("City", ["soundex", "first_4"]),',
      '        ("State", ["exact"]),',
      '        ("Employer", ["soundex", "first_significant_token"]),',
      '        ("Occupation", ["soundex", "first_token"]),',
      '        ("Address1", ["first_5", "first_token"])',
      '    ]',
      '    ',
      '    for field, transforms in single_configs:',
      '        for transform in transforms:',
      '            rules.append({',
      '                "fields": [field],',
      '                "transforms": [transform],',
      '                "separator": "|",',
      '                "name": f"{field}_{transform}"',
      '            })',
      '    ',
      '    # Two-field combinations (20 rules)',
      '    two_field_combos = [',
      '        (("DonorLast", "soundex"), ("DonorFirst", "first_3")),',
      '        (("DonorLast", "soundex"), ("Zip", "zip5")),',
      '        (("DonorLast", "first_3"), ("Zip", "zip5")),',
      '        (("DonorLast", "soundex"), ("City", "soundex")),',
      '        (("DonorLast", "first_3"), ("City", "first_4")),',
      '        (("DonorFirst", "soundex"), ("Zip", "zip5")),',
      '        (("DonorFirst", "first_3"), ("DonorLast", "first_3")),',
      '        (("Address1", "first_5"), ("Zip", "zip5")),',
      '        (("Address1", "first_5"), ("City", "soundex")),',
      '        (("Employer", "first_significant_token"), ("Occupation", "first_token")),',
      '        (("Employer", "soundex"), ("DonorLast", "soundex")),',
      '        (("City", "exact"), ("State", "exact")),',
      '        (("DonorLast", "soundex"), ("Employer", "first_significant_token")),',
      '        (("DonorFirst", "soundex"), ("DonorLast", "soundex")),',
      '        (("Zip", "zip5"), ("State", "exact")),',
      '        (("Address1", "first_token"), ("Zip", "zip5")),',
      '        (("Occupation", "first_token"), ("City", "soundex")),',
      '        (("DonorLast", "first_4"), ("Zip", "zip3")),',
      '        (("DonorFirst", "first_4"), ("City", "first_4")),',
      '        (("Employer", "first_significant_token"), ("City", "soundex"))',
      '    ]',
      '    ',
      '    for (f1, t1), (f2, t2) in two_field_combos:',
      '        rules.append({',
      '            "fields": [f1, f2],',
      '            "transforms": [t1, t2],',
      '            "separator": "|",',
      '            "name": f"{f1}_{t1}+{f2}_{t2}"',
      '        })',
      '    ',
      '    # Three-field combinations (10 rules)',
      '    three_field_combos = [',
      '        (("DonorLast", "soundex"), ("DonorFirst", "first_3"), ("Zip", "zip5")),',
      '        (("DonorLast", "first_3"), ("City", "soundex"), ("State", "exact")),',
      '        (("Address1", "first_5"), ("City", "first_4"), ("Zip", "zip5")),',
      '        (("DonorLast", "soundex"), ("Employer", "first_significant_token"), ("Occupation", "first_token")),',
      '        (("DonorFirst", "soundex"), ("DonorLast", "soundex"), ("Zip", "zip5")),',
      '        (("DonorLast", "first_3"), ("Address1", "first_5"), ("Zip", "zip5")),',
      '        (("Employer", "soundex"), ("Occupation", "first_token"), ("City", "soundex")),',
      '        (("DonorFirst", "first_3"), ("DonorLast", "first_3"), ("City", "first_4")),',
      '        (("DonorLast", "soundex"), ("Zip", "zip5"), ("State", "exact")),',
      '        (("Address1", "first_token"), ("City", "soundex"), ("State", "exact"))',
      '    ]',
      '    ',
      '    for (f1, t1), (f2, t2), (f3, t3) in three_field_combos:',
      '        rules.append({',
      '            "fields": [f1, f2, f3],',
      '            "transforms": [t1, t2, t3],',
      '            "separator": "|",',
      '            "name": f"{f1}_{t1}+{f2}_{t2}+{f3}_{t3}"',
      '        })',
      '    ',
      '    # Assign cohort tags (10 rules per cohort)',
      '    final_rules = rules[:50]',
      '    for i, rule in enumerate(final_rules):',
      '        rule["cohort"] = (i // 10) + 1  # Cohorts 1-5',
      '        rule["score"] = 0.0  # Initial score',
      '    ',
      '    return final_rules',
      '',
      'def evaluate_blocking_rule_evolutionary(rule, donors, w, comparison_budget):',
      '    """',
      '    Evaluate a blocking rule by running limited comparisons and counting matches.',
      '    ',
      '    Returns: number of matches found within comparison budget',
      '    """',
      '    # Apply blocking rule to create blocks',
      '    blocks = {}',
      '    for donor in donors:',
      '        key = generate_blocking_key_from_rule(donor, rule)',
      '        if key:',
      '            if key not in blocks:',
      '                blocks[key] = []',
      '            blocks[key].append(donor)',
      '    ',
      '    if not blocks:',
      '        return 0.0',
      '    ',
      '    # Calculate total available comparisons',
      '    total_pairs_available = sum(len(block) * (len(block) - 1) // 2 for block in blocks.values())',
      '    ',
      '    if total_pairs_available == 0:',
      '        return 0.0',
      '    ',
      '    # Proportionally sample from each block',
      '    pairs_to_compare = []',
      '    for block_key, block_donors in blocks.items():',
      '        block_size = len(block_donors)',
      '        if block_size < 2:',
      '            continue',
      '        ',
      '        block_pairs_available = block_size * (block_size - 1) // 2',
      '        # Allocate comparisons proportionally',
      '        num_from_block = int(comparison_budget * block_pairs_available / total_pairs_available)',
      '        ',
      '        # Generate all pairs in block',
      '        block_pairs = []',
      '        for i in range(block_size):',
      '            for j in range(i + 1, block_size):',
      '                block_pairs.append((block_donors[i], block_donors[j]))',
      '        ',
      '        # Sample from this block',
      '        if num_from_block < len(block_pairs):',
      '            sampled = random.sample(block_pairs, num_from_block)',
      '        else:',
      '            sampled = block_pairs',
      '        ',
      '        pairs_to_compare.extend(sampled)',
      '    ',
      '    # Limit to budget (in case of rounding)',
      '    if len(pairs_to_compare) > comparison_budget:',
      '        pairs_to_compare = random.sample(pairs_to_compare, comparison_budget)',
      '    ',
      '    # Score pairs with ML model and count matches',
      '    threshold = 0.7  # Standard threshold',
      '    matches_found = 0',
      '    ',
      '    for a, b in pairs_to_compare:',
      '        x = features(a, b)',
      '        z = w[-1]  # bias',
      '        for t in range(len(x)):',
      '            z += w[t] * x[t]',
      '        p = 1.0 / (1.0 + math.exp(-z))',
      '        if p >= threshold:',
      '            matches_found += 1',
      '    ',
      '    return float(matches_found)',
      '',
      'def generate_rule_variations(parent_rules, num_variants=25, severity="normal"):',
      '    """',
      '    Generate new rules by mutating and combining top performers.',
      '    ',
      '    severity: "normal" or "high" (high = more radical mutations)',
      '    """',
      '    variants = []',
      '    ',
      '    all_fields = ["DonorFirst", "DonorLast", "Address1", "City", "State", "Zip", "Employer", "Occupation"]',
      '    all_transforms = {',
      '        "DonorFirst": ["soundex", "first_3", "first_4", "exact"],',
      '        "DonorLast": ["soundex", "first_3", "first_4", "exact"],',
      '        "Address1": ["first_5", "first_token", "exact"],',
      '        "City": ["soundex", "first_4", "exact"],',
      '        "State": ["exact"],',
      '        "Zip": ["zip5", "zip3", "exact"],',
      '        "Employer": ["soundex", "first_token", "first_significant_token", "first_4"],',
      '        "Occupation": ["soundex", "first_token", "first_significant_token", "first_4"]',
      '    }',
      '    ',
      '    for _ in range(num_variants):',
      '        # Pick a random parent',
      '        parent = random.choice(parent_rules)',
      '        mutation_type = random.choice(["mutate_transform", "add_field", "remove_field", "crossover"])',
      '        ',
      '        if mutation_type == "mutate_transform" and parent["fields"]:',
      '            # Mutate one transformation',
      '            new_fields = parent["fields"][:]',
      '            new_transforms = parent["transforms"][:]',
      '            idx = random.randint(0, len(new_fields) - 1)',
      '            field = new_fields[idx]',
      '            if field in all_transforms:',
      '                new_transforms[idx] = random.choice(all_transforms[field])',
      '            variant = {',
      '                "fields": new_fields,',
      '                "transforms": new_transforms,',
      '                "separator": "|",',
      '                "name": "+".join(f"{f}_{t}" for f, t in zip(new_fields, new_transforms))',
      '            }',
      '            variants.append(variant)',
      '        ',
      '        elif mutation_type == "add_field" and len(parent["fields"]) < 3:',
      '            # Add a new field',
      '            available_fields = [f for f in all_fields if f not in parent["fields"]]',
      '            if available_fields:',
      '                new_field = random.choice(available_fields)',
      '                new_transform = random.choice(all_transforms[new_field])',
      '                variant = {',
      '                    "fields": parent["fields"] + [new_field],',
      '                    "transforms": parent["transforms"] + [new_transform],',
      '                    "separator": "|",',
      '                    "name": "+".join(f"{f}_{t}" for f, t in zip(',
      '                        parent["fields"] + [new_field],',
      '                        parent["transforms"] + [new_transform]',
      '                    ))',
      '                }',
      '                variants.append(variant)',
      '        ',
      '        elif mutation_type == "remove_field" and len(parent["fields"]) > 1:',
      '            # Remove a random field',
      '            idx = random.randint(0, len(parent["fields"]) - 1)',
      '            new_fields = parent["fields"][:idx] + parent["fields"][idx+1:]',
      '            new_transforms = parent["transforms"][:idx] + parent["transforms"][idx+1:]',
      '            variant = {',
      '                "fields": new_fields,',
      '                "transforms": new_transforms,',
      '                "separator": "|",',
      '                "name": "+".join(f"{f}_{t}" for f, t in zip(new_fields, new_transforms))',
      '            }',
      '            variants.append(variant)',
      '        ',
      '        elif mutation_type == "crossover" and len(parent_rules) > 1:',
      '            # Combine two parents',
      '            parent2 = random.choice([r for r in parent_rules if r != parent])',
      '            # Take fields from parent1, transforms from parent2',
      '            min_len = min(len(parent["fields"]), len(parent2["transforms"]))',
      '            if min_len > 0:',
      '                variant = {',
      '                    "fields": parent["fields"][:min_len],',
      '                    "transforms": parent2["transforms"][:min_len],',
      '                    "separator": "|",',
      '                    "name": "+".join(f"{f}_{t}" for f, t in zip(',
      '                        parent["fields"][:min_len],',
      '                        parent2["transforms"][:min_len]',
      '                    ))',
      '                }',
      '                variants.append(variant)',
      '    ',
      '    return variants[:num_variants]',
      '',
      'def select_cohort_survivors(cohorts, num_rounds, round_num):',
      '    """',
      '    Select top 5 rules from each cohort with diversity constraints.',
      '    ',
      '    Cohort 1: Top 5 by raw score (no penalty)',
      '    Cohort 2-5: Top 5 by adjusted score (penalized for similarity to previous cohorts)',
      '    """',
      '    all_survivors = []',
      '    ',
      '    for cohort_idx, cohort_rules in enumerate(cohorts):',
      '        if cohort_idx == 0:',
      '            # Cohort 1: Pure performance',
      '            cohort_rules.sort(key=lambda x: x[0], reverse=True)',
      '            survivors = cohort_rules[:5]',
      '            all_survivors.append(survivors)',
      '            print(f"  Cohort 1: Top 5 by performance (no diversity penalty)")',
      '            for i, (score, rule) in enumerate(survivors, 1):',
      '                print(f"    {i}. {rule[\'name\']}: {score:.1f} matches")',
      '        else:',
      '            # Cohorts 2-5: Penalize similarity to previous cohorts',
      '            adjusted_scores = []',
      '            for score, rule in cohort_rules:',
      '                # Calculate max similarity to any previous cohort',
      '                max_similarity = 0.0',
      '                for prev_cohort in all_survivors:',
      '                    for (prev_score, prev_rule) in prev_cohort:',
      '                        similarity = calculate_rule_similarity(rule, prev_rule)',
      '                        max_similarity = max(max_similarity, similarity)',
      '                ',
      '                # Diversity bonus (higher is better)',
      '                diversity_bonus = (1 - max_similarity) * 30',
      '                adjusted_score = score + diversity_bonus',
      '                adjusted_scores.append((adjusted_score, score, rule))',
      '            ',
      '            # Sort by adjusted score',
      '            adjusted_scores.sort(key=lambda x: x[0], reverse=True)',
      '            survivors = [(raw_score, rule) for (adj, raw_score, rule) in adjusted_scores[:5]]',
      '            all_survivors.append(survivors)',
      '            ',
      '            print(f"  Cohort {cohort_idx + 1}: Top 5 with diversity from previous cohorts")',
      '            for i, (score, rule) in enumerate(survivors, 1):',
      '                print(f"    {i}. {rule[\'name\']}: {score:.1f} matches")',
      '    ',
      '    return all_survivors',
      '',
      'def measure_cross_cohort_diversity(survivors):',
      '    """',
      '    Measure average diversity across all cohorts.',
      '    Returns value between 0 (all identical) and 1 (completely different).',
      '    """',
      '    total_similarity = 0.0',
      '    comparisons = 0',
      '    ',
      '    for i, cohort1 in enumerate(survivors):',
      '        for j, cohort2 in enumerate(survivors):',
      '            if i >= j:',
      '                continue',
      '            # Average similarity between cohorts',
      '            cohort_similarity = 0.0',
      '            for (score1, rule1) in cohort1:',
      '                for (score2, rule2) in cohort2:',
      '                    cohort_similarity += calculate_rule_similarity(rule1, rule2)',
      '            cohort_similarity /= (len(cohort1) * len(cohort2))',
      '            total_similarity += cohort_similarity',
      '            comparisons += 1',
      '    ',
      '    avg_similarity = total_similarity / comparisons if comparisons > 0 else 0.0',
      '    diversity = 1 - avg_similarity',
      '    return diversity',
      '',
      'def calculate_rule_similarity(rule1, rule2):',
      '    """',
      '    Calculate similarity between two rules based on shared fields.',
      '    Returns value between 0 (completely different) and 1 (identical).',
      '    """',
      '    fields1 = set(rule1.get("fields", []))',
      '    fields2 = set(rule2.get("fields", []))',
      '    ',
      '    if not fields1 and not fields2:',
      '        return 1.0',
      '    if not fields1 or not fields2:',
      '        return 0.0',
      '    ',
      '    intersection = len(fields1 & fields2)',
      '    union = len(fields1 | fields2)',
      '    ',
      '    return intersection / union if union > 0 else 0.0',
      '',
      '# Wrapper for backward compatibility',
      'def features(a, b):',
      '    """Calculate features using unified module."""',
      '    return calculate_features(a, b)',
      '',
      'def features_dict(a, b):',
      '    """Return features as a dict for storage in training data."""',
      '    f = features(a, b)',
      '    return {',
      '        "nameSim": f[0], "lastSim": f[1], "addrSim": f[2], "empSim": f[3], "occSim": f[4],',
      '        "zipMatch": f[5], "cityMatch": f[6],',
      '        "name_last": f[7], "name_addr": f[8], "name_emp": f[9], "name_occ": f[10],',
      '        "last_addr": f[11], "last_emp": f[12], "last_occ": f[13],',
      '        "addr_emp": f[14], "addr_occ": f[15], "emp_occ": f[16]',
      '    }',
      '',
      '# ----------------------------',
      '# TTY input that works even when stdin is piped',
      'def read_tty(prompt=""):',
      '    try:',
      '        if sys.stdin and hasattr(sys.stdin, "isatty") and sys.stdin.isatty():',
      '            return input(prompt)',
      '        with open("/dev/tty") as tty:',
      '            if prompt:',
      '                print(prompt, end="", flush=True)',
      '            return tty.readline().rstrip("\\n")',
      '    except Exception:',
      '        return ""',
      '',
      'def show_pair_and_get_label(i, total, a, b, x, p):',
      '    print(f"[{i}/{total}]")',
      '    def fmt(o):',
      '        nm = (o.get("DonorFirst","")+" "+o.get("DonorLast","")).strip()',
      '        ad = ", ".join([s for s in [o.get("Address1",""), o.get("City",""), o.get("State","")] if s])',
      '        em = " | ".join([s for s in [o.get("Employer",""), o.get("Occupation","")] if s])',
      '        dt = o.get("ReceiptDate", "").strip() or "No date"',
      '        return nm+"\\n"+ad+"\\n"+em+"\\n"+"Donated: "+dt',
      '    print("A:"); print(fmt(a))',
      '    print("B:"); print(fmt(b))',
      '    # Show confidence as percentage',
      '    confidence_pct = p * 100',
      '    print(f"Model confidence: {confidence_pct:.1f}% match")',
      '    while True:',
      '        s = read_tty("Label this pair (1=match, 0=not match, 2=skip): ").strip()',
      '        if s in ("0","1","2"):',
      '            return int(s)',
      '        print("Please enter 1, 0, or 2.")',
      '',
      '# ----------------------------',
      '# Stable keys and candidate generators',
      'def stable_pair_key(a_obj, b_obj):',
      '    a = (str(a_obj.get("_origin","C")), int(a_obj.get("_rownum", 0)))',
      '    b = (str(b_obj.get("_origin","C")), int(b_obj.get("_rownum", 0)))',
      '    return (a, b) if a <= b else (b, a)',
      '',
      'def cold_start_candidates(window_rows, want, seen_pairs, donor_usage_count, max_usage=3):',
      '    # Address-forward scoring. Skip exact name+address dupes and already-seen pairs.',
      '    cands = []; L = len(window_rows)',
      '    if L < 2: return []',
      '    limit = min(L, 2500)',
      '    for i in range(limit):',
      '        a = window_rows[i]',
      '        for j in range(i+1, limit):',
      '            b = window_rows[j]',
      '            k = stable_pair_key(a, b)',
      '            if k in seen_pairs:',
      '                continue',
      '            # Skip overused donors',
      '            ra = (a.get("_origin","C"), a.get("_rownum",0))',
      '            rb = (b.get("_origin","C"), b.get("_rownum",0))',
      '            if donor_usage_count.get(ra, 0) >= max_usage or donor_usage_count.get(rb, 0) >= max_usage:',
      '                continue',
      '            fullA = (a.get("DonorFirst","")+" "+a.get("DonorLast","")).strip().upper()',
      '            fullB = (b.get("DonorFirst","")+" "+b.get("DonorLast","")).strip().upper()',
      '            addrA = (a.get("Address1","") or "").strip().upper()',
      '            addrB = (b.get("Address1","") or "").strip().upper()',
      '            if fullA == fullB and addrA and addrA == addrB:',
      '                continue',
      '            x = features(a,b)',
      '            score = 0.60*x[2] + 0.25*x[0] + 0.15*x[3]',
      '            if score >= 0.75 or x[2] >= 0.80:',
      '                cands.append((score, a, b, x))',
      '            if len(cands) >= want*80:',
      '                break',
      '        if len(cands) >= want*80:',
      '            break',
      '    cands.sort(key=lambda t: -t[0])',
      '    chosen = []; used = set()',
      '    for _, a, b, x in cands:',
      '        # one-use per row in a batch',
      '        ra = (a.get("_origin","C"), a.get("_rownum",0))',
      '        rb = (b.get("_origin","C"), b.get("_rownum",0))',
      '        if ra in used or rb in used:',
      '            continue',
      '        chosen.append((a, b, x))',
      '        used.add(ra); used.add(rb)',
      '        if len(chosen) >= want:',
      '            break',
      '    return chosen',
      '',
      'def uncertain_candidates(window_rows, want, seen_pairs, w, donor_usage_count, max_usage=3):',
      '    # Pairs closest to 0.5 under current model, skipping seen ones.',
      '    picks = []; L = len(window_rows)',
      '    if L < 2: return []',
      '    limit = min(L, 5000)',
      '    # More aggressive sampling to find uncertain pairs',
      '    if limit <= 2000:',
      '        step = 1  # Dense sampling for smaller windows',
      '    else:',
      '        step = max(1, limit // 1500)  # More dense than before',
      '    sampled = 0',
      '    # Increase search effort',
      '    max_samples = want * 1000',
      '    for i in range(0, limit, step):',
      '        a = window_rows[i]',
      '        for j in range(i+1, limit, step):',
      '            b = window_rows[j]',
      '            k = stable_pair_key(a, b)',
      '            if k in seen_pairs:',
      '                continue',
      '            # Skip overused donors',
      '            ra = (a.get("_origin","C"), a.get("_rownum",0))',
      '            rb = (b.get("_origin","C"), b.get("_rownum",0))',
      '            if donor_usage_count.get(ra, 0) >= max_usage or donor_usage_count.get(rb, 0) >= max_usage:',
      '                continue',
      '            x = features(a, b)',
      '            z = w[-1]',
      '            for t in range(0,5):',
      '                z += w[t]*x[t]',
      '            p = 1.0/(1.0+math.exp(-z))',
      '            u = abs(p - 0.5)',
      '            # Accept slightly wider uncertainty band (0.35 to 0.65)',
      '            if 0.35 <= p <= 0.65:',
      '                picks.append((u, p, a, b, x, p))',
      '            sampled += 1',
      '            if sampled >= max_samples:',
      '                break',
      '        if sampled >= max_samples:',
      '            break',
      '    # sort by lowest uncertainty, then prefer a bit higher p as tie-break',
      '    picks.sort(key=lambda t: (t[0], -t[1]))',
      '    chosen = []; used_rows = set()',
      '    for _, __, a, b, x, p in picks:',
      '        ra = (a.get("_origin","C"), a.get("_rownum",0))',
      '        rb = (b.get("_origin","C"), b.get("_rownum",0))',
      '        if ra in used_rows or rb in used_rows:',
      '            continue',
      '        chosen.append((a, b, x, p))',
      '        used_rows.add(ra); used_rows.add(rb)',
      '        if len(chosen) >= want:',
      '            break',
      '    return chosen',
      '',
