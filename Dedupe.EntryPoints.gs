      '        if new_rule["required_fields"] and random.random() < 0.5:',
      '            # Remove a required field',
      '            new_rule["required_fields"].pop(random.randint(0, len(new_rule["required_fields"]) - 1))',
      '        else:',
      '            # Add a required field from current fields',
      '            available = [f for f in new_rule["fields"] if f not in new_rule["required_fields"]]',
      '            if available:',
      '                new_rule["required_fields"].append(random.choice(available))',
      '    new_rule["name"] = " + ".join([f"{t}({f})" if t != "none" else f for f, t in zip(new_rule["fields"], new_rule["transforms"])])',
      '    return new_rule',
      '',
      '# Rule crossover',
      'def crossover_rules(rule1, rule2):',
      '    all_fields = list(set(rule1["fields"] + rule2["fields"]))',
      '    if len(all_fields) > 4:',
      '        all_fields = random.sample(all_fields, 4)',
      '    transforms = []',
      '    all_transforms = ["soundex", "lower", "first2", "first3", "first4", "first5", "first_token", "last_token", "zip3", "employer_token", "year", "month", "none"]',
      '    for field in all_fields:',
      '        if field in rule1["fields"]:',
      '            idx = rule1["fields"].index(field)',
      '            transforms.append(rule1["transforms"][idx])',
      '        elif field in rule2["fields"]:',
      '            idx = rule2["fields"].index(field)',
      '            transforms.append(rule2["transforms"][idx])',
      '        else:',
      '            transforms.append(random.choice(all_transforms))',
      '    # Combine required fields from both parents',
      '    required_fields = list(set(rule1.get("required_fields", []) + rule2.get("required_fields", [])))',
      '    # Only keep required fields that are in the new field list',
      '    required_fields = [f for f in required_fields if f in all_fields]',
      '    name = " + ".join([f"{t}({f})" if t != "none" else f for f, t in zip(all_fields, transforms)])',
      '    return {"name": name, "fields": all_fields, "transforms": transforms, "separator": "|", "required_fields": required_fields, "cohort": rule1["cohort"], "score": 0.0}',
      '',
      '# Rule similarity',
      '# Calculate adjusted score for diversity cohorts',
      'def calculate_adjusted_score(rule_data, lower_cohort_leaders, donors):',
      '    """',
      '    Calculate adjusted score based on block size comparison with lower cohorts.',
      '    rule_data: (raw_score, blocks, donor_to_blocks, rule)',
      '    lower_cohort_leaders: list of (raw_score, blocks, donor_to_blocks, rule) for top rules from each lower cohort',
      '    Returns: (adjusted_score, avg_multiplier)',
      '    """',
      '    raw_score, blocks, donor_to_blocks, rule = rule_data',
      '    ',
      '    if not lower_cohort_leaders:',
      '        return raw_score, 1.0  # No comparison cohorts - use multiplier of 1.0',
      '    ',
      '    # Find all matched donor pairs from this rule',
      '    matched_donors = set()',
      '    for block_donors in blocks.values():',
      '        if len(block_donors) >= 2:',
      '            for idx, donor in block_donors:',
      '                matched_donors.add(idx)',
      '    ',
      '    # Calculate multiplier for each matched donor',
      '    total_multiplier = 0.0',
      '    for donor_idx in matched_donors:',
      '        # Find smallest block size in current rule that contains this donor',
      '        current_block_sizes = []',
      '        for block_key in donor_to_blocks.get(donor_idx, set()):',
      '            current_block_sizes.append(len(blocks[block_key]))',
      '        ',
      '        if not current_block_sizes:',
      '            continue',
      '        ',
      '        current_min_block_size = min(current_block_sizes)',
      '        ',
      '        # Find smallest block size in lower cohorts that contains this donor',
      '        lower_min_block_size = None',
      '        for _, lower_blocks, lower_donor_to_blocks, _ in lower_cohort_leaders:',
      '            for block_key in lower_donor_to_blocks.get(donor_idx, set()):',
      '                block_size = len(lower_blocks[block_key])',
      '                if lower_min_block_size is None or block_size < lower_min_block_size:',
      '                    lower_min_block_size = block_size',
      '        ',
      '        # Calculate multiplier',
      '        if lower_min_block_size is None:',
      '            # Donor not found in any lower cohort - BIG bonus for unique matches',
      '            multiplier = 10.0',
      '        elif lower_min_block_size <= 50:',
      '            # Lower cohort already has efficient block (<= 50) - duplicate, no value',
      '            multiplier = 0.0',
      '        else:',
      '            # Lower cohort has large block (> 50) - reward efficiency improvements',
      '            # Same block size: 1 - 1 = 0x (no credit)',
      '            # More efficient (200/50): 4 - 1 = 3x bonus (capped at 4x)',
      '            # Less efficient (50/200): 0.25 - 1 = negative (floor at 0)',
      '            ratio = lower_min_block_size / current_min_block_size',
      '            multiplier = max(0.0, min(5.0, ratio) - 1.0)',
      '        ',
      '        total_multiplier += multiplier',
      '    ',
      '    # Total multiplier is the sum across all matched donors (additive, not average)',
      '    final_multiplier = total_multiplier if matched_donors else 1.0',
      '    ',
      '    # For scoring: treat 0 multiplier as 1.0 (no penalty, just no bonus)',
      '    scoring_multiplier = max(1.0, final_multiplier)',
      '    adjusted_score = raw_score * scoring_multiplier',
      '    ',
      '    return adjusted_score, final_multiplier',
      '',
      '# Cohort selection with conditional promotion',
      'def select_cohort_survivors(cohorts_with_data, locked_cohorts, donors, fast_mode):',
      '    """',
      '    Select survivors from each cohort:',
      '    - Cohort 1: Select top 3 by raw score',
      '    - Cohorts 2-5: Select top 3 by adjusted score',
      '    ',
      '    Comparison strategy depends on mode:',
      '    - Fast mode: Each cohort compares only to lower cohorts (sequential optimization)',
      '    - Normal mode: Each cohort compares to ALL other cohorts (parallel diversity)',
      '    ',
      '    cohorts_with_data: list of 5 lists, each containing (raw_score, blocks, donor_to_blocks, rule)',
      '    locked_cohorts: dict {cohort_idx: (score, blocks, donor_to_blocks)} for fast mode',
      '    fast_mode: boolean indicating whether we\'re in fast mode',
      '    """',
      '    # Step 1: Check if any cohort 2-5 beats Cohort 1',
      '    # In fast mode, Cohort 1 might be locked (not in cohorts_with_data)',
      '    if 0 in locked_cohorts:',
      '        # Cohort 1 is locked - use its saved score',
      '        cohort_1_top_score = locked_cohorts[0][0]',
      '    else:',
      '        # Cohort 1 is active - get score from cohorts_with_data',
      '        cohort_1_top_score = max(item[0] for item in cohorts_with_data[0]) if cohorts_with_data[0] else 0.0',
      '    ',
      '    # Step 2: Check for promotion (only in normal mode - fast mode locks sequentially)',
      '    if locked_cohorts:',
      '        # Fast mode: cohorts lock sequentially, no promotion',
      '        print(f"\\nCohort 1 locked (score: {cohort_1_top_score:.1f})")',
      '    else:',
      '        # Normal mode: check if any cohort should be promoted',
      '        challenger_idx = None',
      '        challenger_score = 0.0',
      '        for cohort_idx in range(1, 5):',
      '            if cohorts_with_data[cohort_idx]:',
      '                top_score = max(item[0] for item in cohorts_with_data[cohort_idx])',
      '                if top_score > cohort_1_top_score and top_score > challenger_score:',
      '                    challenger_idx = cohort_idx',
      '                    challenger_score = top_score',
      '        ',
      '        if challenger_idx is not None:',
      '            print(f"\\n*** Cohort {challenger_idx + 1} beats Cohort 1 ({challenger_score:.1f} > {cohort_1_top_score:.1f}) - PROMOTING ***")',
      '            # Shift cohorts: challenger becomes 1, everyone slides down',
      '            new_cohorts = [cohorts_with_data[challenger_idx]]  # New Cohort 1',
      '            for i in range(5):',
      '                if i != challenger_idx:',
      '                    new_cohorts.append(cohorts_with_data[i])',
      '            cohorts_with_data = new_cohorts[:5]  # Keep only 5 cohorts',
      '        else:',
      '            print(f"\\nCohort 1 remains top (score: {cohort_1_top_score:.1f})")',
      '    ',
      '    # Step 3: Select survivors from each cohort',
      '    # Strategy depends on mode:',
      '    # - Fast mode: Sequential (each cohort compares to lower cohorts only)',
      '    # - Normal mode: Cross-cohort (each cohort compares to all others)',
      '    ',
      '    if fast_mode:',
      '        # FAST MODE: Sequential comparison to lower cohorts',
      '        all_survivors = []',
      '        lower_cohort_leaders = []',
      '        ',
      '        # Prepopulate from locked cohorts',
      '        for cohort_idx in sorted(locked_cohorts.keys()):',
      '            lower_cohort_leaders.append(locked_cohorts[cohort_idx])',
      '        ',
      '        for cohort_idx, cohort_data in enumerate(cohorts_with_data):',
      '            if cohort_idx == 0:',
      '                cohort_data.sort(key=lambda x: x[0], reverse=True)',
      '                survivors = cohort_data[:3]',
      '                all_survivors.append(survivors)',
      '                print(f"\\n  Cohort 1 (Performance): Top 3 by raw score")',
      '                for i, (score, blocks, donor_to_blocks, rule) in enumerate(survivors, 1):',
      '                    print(f"    {i}. {score:.1f} matches - {rule[\'name\']}")',
      '                if survivors:',
      '                    lower_cohort_leaders.append(survivors[0])',
      '            else:',
      '                adjusted_scores = []',
      '                for rule_data in cohort_data:',
      '                    raw_score = rule_data[0]',
      '                    adjusted_score, multiplier = calculate_adjusted_score(rule_data, lower_cohort_leaders, donors)',
      '                    adjusted_scores.append((adjusted_score, raw_score, multiplier, rule_data))',
      '                adjusted_scores.sort(key=lambda x: x[0], reverse=True)',
      '                survivors = [rule_data for (adj, raw, mult, rule_data) in adjusted_scores[:3]]',
      '                all_survivors.append(survivors)',
      '                print(f"\\n  Cohort {cohort_idx + 1} (Diversity): Top 3 by adjusted score")',
      '                for i, (adj_score, raw_score, mult, rule_data) in enumerate(adjusted_scores[:3], 1):',
      '                    rule = rule_data[3]',
      '                    print(f"    {i}. {raw_score:.1f} raw / {mult:.2f}x mult / {adj_score:.1f} adjusted - {rule[\'name\']}")',
      '                if survivors:',
      '                    lower_cohort_leaders.append(survivors[0])',
      '    else:',
      '        # NORMAL MODE: Cross-cohort comparison (all cohorts vs all others)',
      '        # First pass: Select top by raw score for all cohorts',
      '        raw_top_1 = []',
      '        for cohort_data in cohorts_with_data:',
      '            cohort_data_sorted = sorted(cohort_data, key=lambda x: x[0], reverse=True)',
      '            raw_top_1.append(cohort_data_sorted[0] if cohort_data_sorted else None)',
      '        ',
      '        # Second pass: Calculate adjusted scores comparing to ALL other cohorts',
      '        all_survivors = []',
      '        for cohort_idx, cohort_data in enumerate(cohorts_with_data):',
      '            if cohort_idx == 0:',
      '                cohort_data.sort(key=lambda x: x[0], reverse=True)',
      '                survivors = cohort_data[:3]',
      '                all_survivors.append(survivors)',
      '                print(f"\\n  Cohort 1 (Performance): Top 3 by raw score")',
      '                for i, (score, blocks, donor_to_blocks, rule) in enumerate(survivors, 1):',
      '                    print(f"    {i}. {score:.1f} matches - {rule[\'name\']}")',
      '            else:',
      '                # Compare to ALL other cohorts (not just lower)',
      '                other_cohort_leaders = [raw_top_1[i] for i in range(5) if i != cohort_idx and raw_top_1[i]]',
      '                adjusted_scores = []',
      '                for rule_data in cohort_data:',
      '                    raw_score = rule_data[0]',
      '                    adjusted_score, multiplier = calculate_adjusted_score(rule_data, other_cohort_leaders, donors)',
      '                    adjusted_scores.append((adjusted_score, raw_score, multiplier, rule_data))',
      '                adjusted_scores.sort(key=lambda x: x[0], reverse=True)',
      '                survivors = [rule_data for (adj, raw, mult, rule_data) in adjusted_scores[:3]]',
      '                all_survivors.append(survivors)',
      '                print(f"\\n  Cohort {cohort_idx + 1} (Diversity vs ALL): Top 3 by adjusted score")',
      '                for i, (adj_score, raw_score, mult, rule_data) in enumerate(adjusted_scores[:3], 1):',
      '                    rule = rule_data[3]',
      '                    print(f"    {i}. {raw_score:.1f} raw / {mult:.2f}x mult / {adj_score:.1f} adjusted - {rule[\'name\']}")',
      '    ',
      '    # Calculate average adjusted scores for each cohort (for mutation strategy)',
      '    cohort_avg_adjusted = []',
      '    for cohort_idx, cohort_data in enumerate(cohorts_with_data):',
      '        if cohort_idx == 0:',
      '            # Cohort 1 uses raw scores',
      '            avg_score = sum(item[0] for item in cohort_data[:3]) / 3 if cohort_data else 0.0',
      '        else:',
      '            # Calculate adjusted scores for top 3',
      '            top_adjusted = []',
      '            if fast_mode:',
      '                # Fast mode: compare to lower cohorts',
      '                comparison_leaders = [all_survivors[i][0] for i in range(cohort_idx) if all_survivors[i]]',
      '            else:',
      '                # Normal mode: compare to all other cohorts',
      '                comparison_leaders = [all_survivors[i][0] for i in range(5) if i != cohort_idx and all_survivors[i]]',
      '            for rule_data in cohort_data[:3]:',
      '                adj, _ = calculate_adjusted_score(rule_data, comparison_leaders, donors)',
      '                top_adjusted.append(adj)',
      '            avg_score = sum(top_adjusted) / len(top_adjusted) if top_adjusted else 0.0',
      '        cohort_avg_adjusted.append(avg_score)',
      '    ',
      '    return all_survivors, cohort_avg_adjusted',
      '',
      '# Main',
      'parser = argparse.ArgumentParser()',
      'parser.add_argument("--model-url", required=True)',
      'parser.add_argument("--kref-url", required=True)',
      'parser.add_argument("--fec-url", required=True)',
      'parser.add_argument("--rules-url", required=True)',
      'args = parser.parse_args()',
      '',
      'print("="*60)',
      'print("EVOLUTIONARY BLOCKING RULE OPTIMIZATION")',
      'print("="*60)',
      '',
      '# Create SSL context for HTTPS requests',
      'if SSL_CAFILE:',
      '    ssl_context = ssl.create_default_context(cafile=SSL_CAFILE)',
      'else:',
      '    ssl_context = ssl.create_default_context()',
      '',
      '# Load model',
      'print("\\nLoading model data...")',
      'with urllib.request.urlopen(args.model_url, context=ssl_context) as response:',
      '    model_data = json.loads(response.read().decode("utf-8"))',
      'w = model_data.get("weights")',
      'if not w:',
      '    print("✗ No model weights found. Train a model first.")',
      '    sys.exit(1)',
      'print(f"✓ Loaded model with {len(w)} weights")',
      '',
      '# Load donors',
      'print("\\nLoading donor data...")',
      'with urllib.request.urlopen(args.kref_url, context=ssl_context) as response:',
      '    kref_data = response.read().decode("utf-8")',
      '    kref_donors = list(csv.DictReader(io.StringIO(kref_data)))',
      'print(f"✓ Loaded {len(kref_donors)} KREF donors")',
      'with urllib.request.urlopen(args.fec_url, context=ssl_context) as response:',
      '    fec_data = response.read().decode("utf-8")',
      '    fec_donors = list(csv.DictReader(io.StringIO(fec_data)))',
      'print(f"✓ Loaded {len(fec_donors)} FEC donors")',
      'donors = kref_donors + fec_donors',
      'print(f"✓ Total donors: {len(donors)}")',
      '',
      '# Load rules',
      'print("\\nLoading initial rules...")',
      'with urllib.request.urlopen(args.rules_url, context=ssl_context) as response:',
      '    rules_data = response.read().decode("utf-8")',
      '    rules_reader = csv.DictReader(io.StringIO(rules_data))',
      '    rules = []',
      '    for row in rules_reader:',
      '        required = row.get("Required Fields", "").strip()',
      '        required_fields = [f.strip() for f in required.split(",") if f.strip()] if required else []',
      '        rules.append({',
      '            "name": row["Rule Name"],',
      '            "fields": [f.strip() for f in row["Fields"].split(",")],',
      '            "transforms": [t.strip() for t in row["Transforms"].split(",")],',
      '            "separator": row["Separator"],',
      '            "required_fields": required_fields,',
      '            "cohort": int(row["Cohort"]),',
      '            "score": float(row["Score"])',
      '        })',
      'print(f"✓ Loaded {len(rules)} rules")',
      '',
      '# Condense',
      'print("\\nCondensing exact matches...")',
      'donors = condense_exact_matches(donors)',
      '',
      '# Mode selection',
      'print("\\n" + "="*60)',
      'print("EVOLUTION MODE SELECTION")',
      'print("="*60)',
      'print("n = Normal mode (evaluate all cohorts every round)")',
      'print("f = Fast mode (lock cohorts one-by-one when stable)")',
      'print("="*60)',
      'mode = read_tty("\\nSelect mode (n/f): ").strip().lower()',
      'fast_mode = (mode == "f")',
      '',
      'if fast_mode:',
      '    print("\\n*** FAST MODE ENABLED ***")',
      '    print("Cohorts will lock when stable (top 3 same + no change for 10 rounds + score > 100)")',
      '    print("Population: ~10 rules per cohort (not 50)")',
      '    # Save original rules for initializing new cohorts',
      '    original_rules = rules[:]',
      '    # In fast mode, only keep Cohort 1 rules to start',
      '    rules = [r for r in rules if r["cohort"] == 1]',
      '    print(f"Starting with {len(rules)} Cohort 1 rules")',
      'else:',
      '    print("\\n*** NORMAL MODE ***")',
      '    print("Evaluating all cohorts every round")',
      '    original_rules = None',
      '',
      '# Fast mode tracking',
      'locked_cohorts = {}  # {cohort_idx: (score, blocks, donor_to_blocks)}',
      'cohort_history = {i: [] for i in range(5)}  # Track top score history for each cohort',
      'active_cohort = 0  # Which cohort we\'re currently evolving in fast mode',
      '',
      '# Track previous round multipliers for each cohort (for breakthrough detection)',
      'prev_cohort_multipliers = {i: None for i in range(5)}  # Top 3 multipliers from last round (None = no previous round)',
      '',
      '# Persistent cross-round cache for top 3 rules per cohort',
      '# Structure: {rule_signature: {block_key: {"matches": X, "comparisons": Y, "donor_set": frozenset, "done": bool}}}',
      'persistent_cache = {}',
      '',
      '# Track which rules are in current top 3 per cohort (for cache cleanup)',
      'current_top_3_signatures = set()',
      '',
      '# Evolution',
      'round_num = 0',
      'comparison_budget = 100000  # Base budget, scales up in fast mode',
      'if fast_mode:',
      '    print(f"\\nStarting evolution (budget scales: 100k→200k→300k→400k→500k per cohort)")',
      'else:',
      '    print(f"\\nStarting evolution (budget: {comparison_budget:,} comparisons per rule)")',
      'print(f"To stop evolution early: touch {early_stop_file}\\n")',
      '',
      'while not check_early_stop():',
      '    round_num += 1',
      '    print("\\n" + "="*60)',
      '    print(f"ROUND {round_num}")',
      '    print("="*60)',
      '    ',
      '    # Update comparison budget for fast mode (scales with cohort)',
      '    if fast_mode:',
      '        comparison_budget = (active_cohort + 1) * 100000',
      '        locked_list = [i+1 for i in sorted(locked_cohorts.keys())]',
      '        print(f"\\n[FAST MODE] Active: Cohort {active_cohort + 1} | Locked: {locked_list} | Budget: {comparison_budget:,}")',
      '    ',
      '    # Evaluate all rules (in fast mode, only active cohort rules exist)',
      '    print(f"\\nEvaluating {len(rules)} rules...")',
      '    rule_evaluations = {}',
      '    block_cache = {}  # Cache: block_signature -> (score, blocks, donor_to_blocks)',
      '    incomplete_blocks_registry = {}  # Track incomplete blocks for retroactive credits',
      '    ',
      '    exact_cache_hits = 0',
      '    subset_reuse_hits = 0',
      '    ',
      '    for rule in rules:',
      '        score, blocks, donor_to_blocks, was_cached, incomplete_block_info = evaluate_blocking_rule(',
      '            rule, donors, w, comparison_budget, block_cache, incomplete_blocks_registry, persistent_cache)',
      '        rule["score"] = score',
      '        rule_evaluations[id(rule)] = (score, blocks, donor_to_blocks, rule)',
      '        ',
      '        # Register incomplete blocks for retroactive credits',
      '        if incomplete_block_info:',
      '            incomplete_blocks_registry[id(rule)] = {',
      '                "rule": rule,',
      '                "blocks": incomplete_block_info,',
      '                "retro_credits": 0',
      '            }',
      '        ',
      '        if was_cached == True:  # Exact match',
      '            exact_cache_hits += 1',
      '        elif was_cached:  # Subset reuse (any other truthy value)',
      '            subset_reuse_hits += 1',
      '    ',
      '    # Apply retroactive credits to incomplete rules',
      '    total_retro_credits = 0',
      '    for rule_id, rule_info in incomplete_blocks_registry.items():',
      '        retro_credits = rule_info["retro_credits"]',
      '        if retro_credits > 0:',
      '            rule_info["rule"]["score"] += retro_credits',
      '            total_retro_credits += retro_credits',
      '    ',
      '    # Report caching and retroactive credits',
      '    if exact_cache_hits > 0 or subset_reuse_hits > 0:',
      '        print(f"  Cache: {exact_cache_hits} exact hits, {subset_reuse_hits} subset reuse")',
      '    if total_retro_credits > 0:',
      '        incomplete_count = len(incomplete_blocks_registry)',
      '        print(f"  Retroactive: +{total_retro_credits} matches to {incomplete_count} incomplete rules")',
      '    ',
      '    # Check for early stop after evaluation',
      '    if check_early_stop():',
      '        break',
      '    ',
      '    # Group by cohort',
      '    cohorts_with_data = [[] for _ in range(5)]',
      '    for rule in rules:',
      '        cohort_idx = rule["cohort"] - 1',
      '        rule_data = rule_evaluations[id(rule)]',
      '        cohorts_with_data[cohort_idx].append(rule_data)',
      '    ',
      '    # Select survivors (returns survivors and average adjusted scores)',
      '    survivors, cohort_avg_adjusted = select_cohort_survivors(cohorts_with_data, locked_cohorts, donors, fast_mode)',
      '    ',
      '    # UPDATE PERSISTENT CACHE: Track top 3 per cohort and cleanup',
      '    new_top_3_signatures = set()',
      '    ',
      '    # Include locked cohorts (fast mode) - they should keep their cache',
      '    if fast_mode:',
      '        for cohort_idx, locked_data in locked_cohorts.items():',
      '            _, _, _, rule = locked_data',
      '            rule_sig = get_rule_signature(rule)',
      '            new_top_3_signatures.add(rule_sig)',
      '    ',
      '    # Include current survivors',
      '    for cohort_idx, cohort_survivors in enumerate(survivors):',
      '        # Get top 3 rules for this cohort',
      '        for i, survivor_data in enumerate(cohort_survivors[:3]):',
      '            if i >= 3:',
      '                break',
      '            _, _, _, rule = survivor_data',
      '            rule_sig = get_rule_signature(rule)',
      '            new_top_3_signatures.add(rule_sig)',
      '    ',
      '    # Cleanup: Remove cache entries for rules not in current top 3',
      '    signatures_to_remove = set(persistent_cache.keys()) - new_top_3_signatures',
      '    for sig in signatures_to_remove:',
      '        del persistent_cache[sig]',
      '    ',
      '    # Update tracking',
      '    current_top_3_signatures = new_top_3_signatures',
      '    ',
      '    # Report cache stats',
      '    if len(persistent_cache) > 0:',
      '        total_cached_blocks = sum(len(blocks) for blocks in persistent_cache.values())',
      '        done_blocks = sum(1 for rule_data in persistent_cache.values() ',
      '                         for block_data in rule_data.values() if block_data.get("done", False))',
      '        if done_blocks > 0:',
      '            print(f"  Persistent cache: {len(persistent_cache)} rules, {total_cached_blocks} blocks ({done_blocks} done)")',
      '    ',
      '    # Fast mode: Check convergence for active cohort',
      '    if fast_mode and active_cohort < 5:',
      '        cohort_survivors = survivors[active_cohort]',
      '        if len(cohort_survivors) >= 3:',
      '            # Get top 3 scores and rules',
      '            top_3_scores = [cohort_survivors[0][0], cohort_survivors[1][0], cohort_survivors[2][0]]',
      '            top_3_rules = [cohort_survivors[0][3], cohort_survivors[1][3], cohort_survivors[2][3]]',
      '            top_score = top_3_scores[0]',
      '            ',
      '            # Record top score in history',
      '            cohort_history[active_cohort].append(top_score)',
      '            ',
      '            # Check convergence requires BOTH identical outcomes AND similar structure',
      '            # Condition 1a: Top 3 all have same score (identical outcomes)',
      '            scores_identical = (top_3_scores[0] == top_3_scores[1] == top_3_scores[2])',
      '            ',
      '            # Condition 1b: At least 2 of top 3 rules are structurally identical',
      '            rules_similar = (rules_are_identical(top_3_rules[0], top_3_rules[1]) or',
      '                            rules_are_identical(top_3_rules[1], top_3_rules[2]) or',
      '                            rules_are_identical(top_3_rules[0], top_3_rules[2]))',
      '            ',
      '            top_3_converged = scores_identical and rules_similar',
      '            ',
      '            # Condition 2: Score unchanged for 10 rounds',
      '            no_change_for_10 = False',
      '            if len(cohort_history[active_cohort]) >= 10:',
      '                last_10_scores = cohort_history[active_cohort][-10:]',
      '                no_change_for_10 = all(s == last_10_scores[0] for s in last_10_scores)',
      '            ',
      '            # Condition 3: Score above threshold',
      '            score_above_100 = cohort_avg_adjusted[active_cohort] > 100.0',
      '            ',
      '            # Debug convergence conditions',
      '            print(f"  [Convergence check: scores_identical={scores_identical}, rules_similar={rules_similar}, no_change_10={no_change_for_10}, score>100={score_above_100}]")',
      '            ',
      '            # Lock if converged',
      '            if top_3_converged and no_change_for_10 and score_above_100:',
      '                print(f"\\n*** COHORT {active_cohort + 1} CONVERGED - LOCKING ***")',
      '                print(f"  Scores identical: ✓")',
      '                print(f"  Rules similar: ✓")',
      '                print(f"  No change for 10 rounds: ✓")',
      '                print(f"  Score > 100: ✓ ({cohort_avg_adjusted[active_cohort]:.1f})")',
      '                ',
      '                # Store top rule and its blocks for diversity scoring',
      '                locked_cohorts[active_cohort] = cohort_survivors[0]  # (score, blocks, donor_to_blocks, rule)',
      '                ',
      '                # Move to next cohort and initialize its rules',
      '                active_cohort += 1',
      '                if active_cohort < 5:',
      '                    # Initialize next cohort from original rule set',
      '                    rules = [r.copy() for r in original_rules if r["cohort"] == active_cohort + 1]',
      '                    print(f"  Initializing Cohort {active_cohort + 1} with {len(rules)} rules")',
      '                    print(f"\\n✓ Round {round_num} complete (cohort transition)")',
      '                    continue  # Skip to next round with new cohort',
      '                # If all cohorts done, continue to exit check below',
      '    ',
      '    # Generate new rules using rank-based mutations',
      '    print("\\nGenerating new rules (rank-based mutations)...")',
      '    new_rules = []',
      '    ',
      '    for cohort_idx, cohort_survivors in enumerate(survivors):',
      '        if len(cohort_survivors) == 0:',
      '            print(f"  Cohort {cohort_idx + 1}: No survivors, skipping")',
      '            continue',
      '        ',
      '        # Fast mode: only active cohort has rules (locked/future cohorts don\'t exist in population)',
      '        if fast_mode and cohort_idx != active_cohort:',
      '            continue',
      '        ',
      '        # Calculate comparison leaders based on mode',
      '        # IMPORTANT: Include locked cohorts for accurate diversity scoring',
      '        if fast_mode:',
      '            # Fast mode: compare to lower cohorts (including locked)',
      '            comparison_leaders = []',
      '            # Add locked cohorts first',
      '            for i in sorted(locked_cohorts.keys()):',
      '                if i < cohort_idx:',
      '                    comparison_leaders.append(locked_cohorts[i])',
      '            # Add active cohorts below current',
      '            for i in range(cohort_idx):',
      '                if i < len(survivors) and survivors[i] and i not in locked_cohorts:',
      '                    comparison_leaders.append(survivors[i][0])',
      '        else:',
      '            # Normal mode: compare to all other cohorts',
      '            comparison_leaders = [survivors[i][0] for i in range(5) if i != cohort_idx and i < len(survivors) and survivors[i]]',
      '        ',
      '        # Special case: Breakthrough detection (diversity cohorts only)',
      '        if cohort_idx > 0 and len(cohort_survivors) >= 3:',
      '            # Calculate adjusted scores and multipliers for top 3 rules',
      '            adjusted_data_top3 = []',
      '            for rule_data in cohort_survivors[:3]:',
      '                adj_score, multiplier = calculate_adjusted_score(rule_data, comparison_leaders, donors)',
      '                adjusted_data_top3.append((adj_score, multiplier, rule_data))',
      '            ',
      '            # Get current multipliers',
      '            current_multipliers = [mult for _, mult, _ in adjusted_data_top3]',
      '            ',
      '            # Check for breakthrough: last round all zero, this round some positive',
      '            # Only check if we have previous round data (not first round)',
      '            prev_multipliers = prev_cohort_multipliers[cohort_idx]',
      '            if prev_multipliers is not None:',
      '                prev_all_zero = all(m <= 0 for m in prev_multipliers)',
      '            else:',
      '                prev_all_zero = False  # First round - no breakthrough detection',
      '            current_has_positive = any(m > 0 for m in current_multipliers)',
      '            ',
      '            # Save current multipliers for next round',
      '            prev_cohort_multipliers[cohort_idx] = current_multipliers[:3]',
      '            ',
      '            # Breakthrough: discard all non-positive rules, distribute offspring among positive ones',
      '            if prev_all_zero and current_has_positive:',
      '                winners = [(adj_score, mult, rule_data) for adj_score, mult, rule_data in adjusted_data_top3 if mult > 0]',
      '                num_winners = len(winners)',
      '                ',
      '                # Sort winners by score (descending) for rounding bias',
      '                winners.sort(key=lambda x: x[0], reverse=True)',
      '                ',
      '                print(f"  Cohort {cohort_idx + 1}: BREAKTHROUGH! {num_winners} rule(s) with positive multiplier")',
      '                for adj_score, mult, _ in winners:',
      '                    print(f"    - multiplier={mult:.2f}x, score={adj_score:.1f}")',
      '                ',
      '                # Distribute 10 offspring evenly, rounding goes to top scores',
      '                base_copies = 10 // num_winners',
      '                extra_copies = 10 % num_winners',
      '                ',
      '                for winner_idx, (adj_score, mult, rule_data) in enumerate(winners):',
      '                    num_copies = base_copies + (1 if winner_idx < extra_copies else 0)',
      '                    winner_rule = rule_data[3]',
      '                    ',
      '                    for i in range(num_copies):',
      '                        copy_rule = {',
      '                            "name": winner_rule["name"],',
      '                            "fields": winner_rule["fields"][:],',
      '                            "transforms": winner_rule["transforms"][:],',
      '                            "separator": winner_rule["separator"],',
      '                            "required_fields": winner_rule.get("required_fields", [])[:],',
      '                            "cohort": cohort_idx + 1,',
      '                            "score": 0.0',
      '                        }',
      '                        new_rules.append(copy_rule)',
      '                ',
      '                print(f"  Created {len(winners)} winners × {base_copies}+{extra_copies} = 10 copies")',
      '                ',
      '                # Skip normal mutation generation for this cohort',
      '                continue',
      '        ',
      '        mutations_per_rank = [4, 2, 1]  # Rank 1, 2, 3',
      '        stuck_count = 0',
      '        normal_count = 0',
      '        ',
      '        for rank_idx, rule_data in enumerate(cohort_survivors[:3]):  # Top 3 ranks',
      '            score, blocks, donor_to_blocks, parent_rule = rule_data',
      '            ',
      '            # Calculate adjusted score for this specific rule',
      '            if cohort_idx == 0:',
      '                # Cohort 1 uses raw score',
      '                adjusted_score = score',
      '            else:',
      '                # Calculate adjusted score for diversity cohorts',
      '                adjusted_score, _ = calculate_adjusted_score(rule_data, comparison_leaders, donors)',
      '            ',
      '            num_mutations = mutations_per_rank[rank_idx]',
      '            ',
      '            # Three states:',
      '            # - adjusted_score == 0: Worthless (multiplier=0), no point preserving',
      '            # - 0 < adjusted_score < 100: Stuck, but has potential (low multiplier)',
      '            # - adjusted_score >= 100: Healthy (good multiplier or high raw count)',
      '            ',
      '            if adjusted_score == 0 and cohort_idx > 0:',
      '                # Score is zero - no point preserving, skip exact copy',
      '                # Just generate mutations (all extreme)',
      '                stuck_count += 1',
      '                for _ in range(num_mutations + 1):  # +1 to make up for skipped copy',
      '                    # Keep mutating until we get a unique rule',
      '                    max_attempts = 20',
      '                    for attempt in range(max_attempts):',
      '                        extreme_mut = parent_rule',
      '                        # Apply 2-3 stacked mutations for radical change',
      '                        for _ in range(random.randint(2, 3)):',
      '                            extreme_mut = mutate_rule(extreme_mut)',
      '                        ',
      '                        # Check if this mutation is unique',
      '                        is_unique = True',
      '                        for existing in new_rules:',
      '                            if rules_are_identical(extreme_mut, existing):',
      '                                is_unique = False',
      '                                break',
      '                        ',
      '                        if is_unique:',
      '                            break',
      '                    ',
      '                    extreme_mut["cohort"] = cohort_idx + 1',
      '                    new_rules.append(extreme_mut)',
      '            ',
      '            elif 0 < adjusted_score < 100.0 and cohort_idx > 0:',
      '                # Rule is stuck but has potential - use mixed mutations',
      '                stuck_count += 1',
      '                ',
      '                # Add exact copy (there\'s something to build on)',
      '                copy_rule = {',
      '                    "name": parent_rule["name"],',
      '                    "fields": parent_rule["fields"][:],',
      '                    "transforms": parent_rule["transforms"][:],',
      '                    "separator": parent_rule["separator"],',
      '                    "required_fields": parent_rule.get("required_fields", [])[:],',
      '                    "cohort": cohort_idx + 1,',
      '                    "score": 0.0',
      '                }',
      '                new_rules.append(copy_rule)',
      '                ',
      '                # First mutation is standard (build on small improvement)',
      '                if num_mutations >= 1:',
      '                    max_attempts = 20',
      '                    for attempt in range(max_attempts):',
      '                        standard_mut = mutate_rule(parent_rule)',
      '                        # Check uniqueness',
      '                        is_unique = True',
      '                        for existing in new_rules:',
      '                            if rules_are_identical(standard_mut, existing):',
      '                                is_unique = False',
      '                                break',
      '                        if is_unique:',
      '                            break',
      '                    standard_mut["cohort"] = cohort_idx + 1',
      '                    new_rules.append(standard_mut)',
      '                ',
      '                # Rest are extreme mutations (radical exploration)',
      '                for _ in range(num_mutations - 1):',
      '                    max_attempts = 20',
      '                    for attempt in range(max_attempts):',
      '                        extreme_mut = parent_rule',
      '                        # Apply 2-3 stacked mutations for radical change',
      '                        for _ in range(random.randint(2, 3)):',
      '                            extreme_mut = mutate_rule(extreme_mut)',
      '                        # Check uniqueness',
      '                        is_unique = True',
      '                        for existing in new_rules:',
      '                            if rules_are_identical(extreme_mut, existing):',
      '                                is_unique = False',
      '                                break',
      '                        if is_unique:',
      '                            break',
      '                    extreme_mut["cohort"] = cohort_idx + 1',
      '                    new_rules.append(extreme_mut)',
      '            ',
      '            else:',
      '                # Normal healthy rule (score >= 100 or Cohort 1)',
      '                normal_count += 1',
      '                ',
      '                # Add exact copy',
      '                copy_rule = {',
      '                    "name": parent_rule["name"],',
      '                    "fields": parent_rule["fields"][:],',
      '                    "transforms": parent_rule["transforms"][:],',
      '                    "separator": parent_rule["separator"],',
      '                    "required_fields": parent_rule.get("required_fields", [])[:],',
      '                    "cohort": cohort_idx + 1,',
      '                    "score": 0.0',
      '                }',
      '                new_rules.append(copy_rule)',
      '                ',
      '                # Normal mutations - ensure each is unique',
      '                for _ in range(num_mutations):',
      '                    max_attempts = 20',
      '                    for attempt in range(max_attempts):',
      '                        mutated = mutate_rule(parent_rule)',
      '                        # Check uniqueness',
      '                        is_unique = True',
      '                        for existing in new_rules:',
      '                            if rules_are_identical(mutated, existing):',
      '                                is_unique = False',
      '                                break',
      '                        if is_unique:',
      '                            break',
      '                    mutated["cohort"] = cohort_idx + 1',
      '                    new_rules.append(mutated)',
      '        ',
      '        if stuck_count > 0:',
      '            print(f"  Cohort {cohort_idx + 1}: Generated 10 rules ({stuck_count} stuck rules with extreme mutations)")',
      '        else:',
      '            print(f"  Cohort {cohort_idx + 1}: Generated 10 rules (rank-based: 5+3+2)")',
      '    ',
      '    # Use ONLY new rules for next generation (50 total)',
      '    # Don\'t re-add survivors - they\'re already the basis for new rules',
      '    rules = new_rules',
      '    ',
      '    # Update cohort numbers for consistency',
      '    for rule in rules:',
      '        # Cohort numbers already set during generation',
      '        pass',
      '    ',
      '    print(f"\\n✓ Round {round_num} complete. Population: {len(rules)} rules")',
      '    ',
      '    # Fast mode: Exit if all cohorts locked',
      '    if fast_mode and len(locked_cohorts) == 5:',
      '        print("\\n" + "="*60)',
      '        print("ALL COHORTS LOCKED - EVOLUTION COMPLETE")',
      '        print("="*60)',
      '        ',
      '        # Reconstruct final rule set from locked cohorts',
      '        final_rules = []',
      '        for cohort_idx in range(5):',
      '            score, blocks, donor_to_blocks, rule = locked_cohorts[cohort_idx]',
      '            rule["score"] = score',
      '            rule["cohort"] = cohort_idx + 1',
      '            rule["rank"] = 1  # Locked cohorts only have 1 rule, so rank is always 1',
      '            final_rules.append(rule)',
      '        ',
      '        # Download rule set',
      '        import os',
      '        downloads_dir = os.path.expanduser("~/Downloads")',
      '        output_csv = os.path.join(downloads_dir, "blocking_rules_evolved.csv")',
      '        print(f"\\nSaving results to {output_csv}...")',
      '        with open(output_csv, "w", newline="") as f:',
      '            writer = csv.writer(f)',
      '            writer.writerow(["Rule Name", "Fields", "Transforms", "Separator", "Required Fields", "Cohort", "Rank"])',
      '            for rule in final_rules:',
      '                required_str = ", ".join(rule.get("required_fields", []))',
      '                writer.writerow([',
      '                    rule["name"],',
      '                    ", ".join(rule["fields"]),',
      '                    ", ".join(rule["transforms"]),',
      '                    rule["separator"],',
      '                    required_str,',
      '                    rule["cohort"],',
      '                    rule["rank"]',
      '                ])',
      '        print(f"✓ Saved {len(final_rules)} evolved rules to:")',
      '        print(f"  {output_csv}")',
      '        ',
      '        break',
      '    ',
      '    # Check for early stop at end of round',
      '    if check_early_stop():',
      '        break',
      '    ',
      '    time.sleep(0.1)',
      '',
      '# Save to Downloads folder',
      'import os',
      'downloads_dir = os.path.expanduser("~/Downloads")',
      'output_csv = os.path.join(downloads_dir, "blocking_rules_evolved.csv")',
      'print(f"\\nSaving results to {output_csv}...")',
      '',
      '# Collect all rules including locked cohorts',
      'all_rules_to_save = []',
      '',
      '# Add locked cohort rules (fast mode)',
      'if locked_cohorts:',
      '    for cohort_idx in sorted(locked_cohorts.keys()):',
      '        score, blocks, donor_to_blocks, rule = locked_cohorts[cohort_idx]',
      '        rule["score"] = score',
      '        rule["cohort"] = cohort_idx + 1',
      '        all_rules_to_save.append(rule)',
      '',
      '# Add active rules',
      'all_rules_to_save.extend(rules)',
      '',
      '# Sort rules by cohort, then by score (descending) and assign ranks',
      'rules_by_cohort = {}',
      'for rule in all_rules_to_save:',
      '    cohort = rule["cohort"]',
      '    if cohort not in rules_by_cohort:',
      '        rules_by_cohort[cohort] = []',
      '    rules_by_cohort[cohort].append(rule)',
      '',
      '# Assign ranks within each cohort',
      'ranked_rules = []',
      'for cohort in sorted(rules_by_cohort.keys()):',
      '    cohort_rules = sorted(rules_by_cohort[cohort], key=lambda r: r.get("score", 0), reverse=True)',
      '    for rank, rule in enumerate(cohort_rules, 1):',
      '        rule["rank"] = rank',
      '        ranked_rules.append(rule)',
      '',
      'with open(output_csv, "w", newline="") as f:',
      '    writer = csv.writer(f)',
      '    writer.writerow(["Rule Name", "Fields", "Transforms", "Separator", "Required Fields", "Cohort", "Rank"])',
      '    for rule in ranked_rules:',
      '        required_str = ", ".join(rule.get("required_fields", []))',
      '        writer.writerow([',
      '            rule["name"],',
      '            ", ".join(rule["fields"]),',
      '            ", ".join(rule["transforms"]),',
      '            rule["separator"],',
      '            required_str,',
      '            rule["cohort"],',
      '            rule["rank"]',
      '        ])',
      'print(f"✓ Saved {len(ranked_rules)} evolved rules to:")',
      'print(f"  {output_csv}")',
      'print("\\n" + "="*60)',
      'print("EVOLUTION COMPLETE")',
      'print("="*60)'
    );

    const pyText = dl_sanitizePyNewlinePrints_(py.join('\n'));
    return ContentService.createTextOutput(pyText).setMimeType(ContentService.MimeType.TEXT);
  }

  // Job bundle for the runner
  if (p.job == '1') {
    const chk = dl_validateToken_(p.token);
    if (!chk.ok) return ContentService.createTextOutput(chk.msg).setMimeType(ContentService.MimeType.TEXT);
    const job = PropertiesService.getDocumentProperties().getProperty('dl_job_json') || '{}';
    return ContentService.createTextOutput(job).setMimeType(ContentService.MimeType.JSON);
  }

  // Diagnostic job bundle endpoint
  if (p.diag_job == '1') {
    const chk = dl_validateToken_(p.token);
    if (!chk.ok) return ContentService.createTextOutput(chk.msg).setMimeType(ContentService.MimeType.TEXT);
    const job = PropertiesService.getDocumentProperties().getProperty('diag_job_json') || '{}';
    return ContentService.createTextOutput(job).setMimeType(ContentService.MimeType.JSON);
  }

  // CSV endpoints for runner input
  if (p.csv == 'kref' || p.csv == 'fec') {
    const chk = dl_validateToken_(p.token);
    if (!chk.ok) return ContentService.createTextOutput(chk.msg).setMimeType(ContentService.MimeType.TEXT);
    const fileId = dl_getTokenCsvFileId_(p.token, p.csv);
    if (!fileId) return ContentService.createTextOutput('No CSV file id').setMimeType(ContentService.MimeType.TEXT);
    const file = DriveApp.getFileById(fileId);
    const out = ContentService.createTextOutput(file.getBlob().getDataAsString());
    out.setMimeType(ContentService.MimeType.CSV);
    return out;
  }

  // Blocking rules CSV endpoint
  if (p.csv == 'blocking_rules') {
    const chk = dl_validateToken_(p.token);
    if (!chk.ok) return ContentService.createTextOutput(chk.msg).setMimeType(ContentService.MimeType.TEXT);
    const ss = SpreadsheetApp.getActive();
    const sheet = ss.getSheetByName('BlockingRules');
    if (!sheet || sheet.getLastRow() < 2) {
      return ContentService.createTextOutput('No blocking rules found').setMimeType(ContentService.MimeType.TEXT);
    }
    const csvContent = exportSheetToCsvString_(sheet);
    const out = ContentService.createTextOutput(csvContent);
    out.setMimeType(ContentService.MimeType.CSV);
    return out;
  }

  // Model endpoint for runner to fetch current weights/prior if any
  if (p.model == '1') {
    const props = PropertiesService.getDocumentProperties();
    const w = props.getProperty('donor_model_weights');
    const fp = props.getProperty('donor_first_pair_table');

    // Read blocking rules from BlockingRules sheet
    const ss = SpreadsheetApp.getActive();
    const blockingSheet = ss.getSheetByName('BlockingRules');
    let allRules = [];
    let matchingRules = [];

    if (blockingSheet && blockingSheet.getLastRow() > 1) {
      const vals = blockingSheet.getDataRange().getValues();
      // Skip header row
      for (let i = 1; i < vals.length; i++) {
        const row = vals[i];
        const ruleName = String(row[0] || '');
        const fieldsStr = String(row[1] || '');
        const transformsStr = String(row[2] || '');
        const separator = String(row[3] || '|');
        const requiredFieldsStr = String(row[4] || '');
        const cohort = Number(row[5]) || 0;
        const score = Number(row[6]) || 0;

        if (ruleName) {
          allRules.push({
            name: ruleName,
            fields: fieldsStr.split(',').map(s => s.trim()).filter(s => s),
            transforms: transformsStr.split(',').map(s => s.trim()).filter(s => s),
            separator: separator,
            required_fields: requiredFieldsStr.split(',').map(s => s.trim()).filter(s => s),
            cohort: cohort,
            score: score
          });
        }
      }

      // Select top 1 from each cohort for matching
      for (let c = 1; c <= 5; c++) {
        const cohortRules = allRules.filter(r => r.cohort === c);
        cohortRules.sort((a, b) => b.score - a.score); // Sort by score desc
        if (cohortRules.length > 0) {
          matchingRules.push(cohortRules[0]); // Top 1 only
        }
      }
      Logger.log('Loaded ' + allRules.length + ' total rules, selected ' + matchingRules.length + ' for matching (top 1 per cohort)');
    }

    const body = {
      weights: w ? JSON.parse(w) : null,
      first_pair_table: fp ? JSON.parse(fp) : {},
      blocking_rules: matchingRules,  // Only top 3 per cohort for matching
      all_blocking_rules: allRules     // All 50 for evolution
    };
    return ContentService.createTextOutput(JSON.stringify(body)).setMimeType(ContentService.MimeType.JSON);
  }

  // Diagnostic script endpoint
  if (p.script == '1') {
    return diagnostic_getScript_();
  }

  // Clear model endpoint - delete saved weights
  if (p.clear == '1') {
    const props = PropertiesService.getDocumentProperties();
    props.deleteProperty('donor_model_weights');
    props.deleteProperty('donor_first_pair_table');
    return ContentService.createTextOutput(JSON.stringify({ ok: true, message: 'Model cleared' })).setMimeType(ContentService.MimeType.JSON);
  }

  // Training data endpoint - fetch existing training rows
  if (p.training == '1') {
    const ss = SpreadsheetApp.getActive();
    const sh = ss.getSheetByName(DONOR_CFG.trainingSheet);

    if (!sh || sh.getLastRow() < 2) {
      return ContentService.createTextOutput(JSON.stringify({ training_rows: [] })).setMimeType(ContentService.MimeType.JSON);
    }

    const vals = sh.getDataRange().getValues();
    const header = vals[0];
    const trainingRows = [];

    for (let i = 1; i < vals.length; i++) {
      const row = vals[i];
      const label = Number(row[0]);
      if (label !== 0 && label !== 1) continue; // Skip unlabeled

      // Parse the row into the format Python expects
      trainingRows.push({
        a: {
          origin: String(row[1] || ''),
          row: Number(row[2] || 0),
          first: String(row[3] || ''),
          last: String(row[4] || ''),
          addr: String(row[5] || ''),
          city: String(row[6] || ''),
          state: String(row[7] || ''),
          zip: String(row[8] || ''),
          employer: String(row[9] || ''),
          occupation: String(row[10] || '')
        },
        b: {
          origin: String(row[11] || ''),
          row: Number(row[12] || 0),
          first: String(row[13] || ''),
          last: String(row[14] || ''),
          addr: String(row[15] || ''),
          city: String(row[16] || ''),
          state: String(row[17] || ''),
          zip: String(row[18] || ''),
          employer: String(row[19] || ''),
          occupation: String(row[20] || '')
        },
        features: {
          nameSim: Number(row[21] || 0),
          lastSim: Number(row[22] || 0),
          addrSim: Number(row[24] || 0),
          empSim: Number(row[31] || 0),
          occSim: Number(row[32] || 0),
          // Compute interactions from base features
          name_last: Number(row[21] || 0) * Number(row[22] || 0),
          name_addr: Number(row[21] || 0) * Number(row[24] || 0),
          name_emp: Number(row[21] || 0) * Number(row[31] || 0),
          name_occ: Number(row[21] || 0) * Number(row[32] || 0),
          last_addr: Number(row[22] || 0) * Number(row[24] || 0),
          last_emp: Number(row[22] || 0) * Number(row[31] || 0),
          last_occ: Number(row[22] || 0) * Number(row[32] || 0),
          addr_emp: Number(row[24] || 0) * Number(row[31] || 0),
          addr_occ: Number(row[24] || 0) * Number(row[32] || 0),
          emp_occ: Number(row[31] || 0) * Number(row[32] || 0)
        },
        label: label
      });
    }

    return ContentService.createTextOutput(JSON.stringify({ training_rows: trainingRows })).setMimeType(ContentService.MimeType.JSON);
  }

  // Nicknames endpoint - serve nickname pairs for enhanced matching
  if (p.nicknames == '1') {
    const pairs = donor_ensureNicknamesSheet_();
    // Convert to object format for easy lookup in Python
    const nicknameMap = {};
    for (const pair of pairs) {
      const name1 = String(pair[0] || '').toUpperCase();
      const name2 = String(pair[1] || '').toUpperCase();
      if (!name1 || !name2) continue;

      // Add bidirectional mappings
      if (!nicknameMap[name1]) nicknameMap[name1] = [];
      if (!nicknameMap[name1].includes(name2)) nicknameMap[name1].push(name2);

      if (!nicknameMap[name2]) nicknameMap[name2] = [];
      if (!nicknameMap[name2].includes(name1)) nicknameMap[name2].push(name1);
    }
    return ContentService.createTextOutput(JSON.stringify({ nicknames: nicknameMap })).setMimeType(ContentService.MimeType.JSON);
  }

  // Campaign Deputy CSV endpoints
  if (p.cd_csv == 'merge' || p.cd_csv == 'cd') {
    return cd_serveCsv_(p.cd_csv, p.token);
  }

  // Campaign Deputy matcher Python script
  if (p.cd_matcher == '1') {
    return cd_getMatcherScript_();
  }

  // Diagnostic analysis Python script
  if (p.diagnostic == '1') {
    return diagnostic_getScript_();
  }

  return ContentService.createTextOutput('Invalid query: ' + activeRoute).setMimeType(ContentService.MimeType.TEXT);
}


function dl_handlePostRequest_(e, routeName) {
  try {
    const p = e.parameter || {};
    const activeRoute = routeName || 'invalid';

    // Handle Campaign Deputy matching results separately
    if (p.cd_result == '1') {
      const chk = cd_validateToken_(p.token);
      if (!chk.ok) {
        return ContentService.createTextOutput(JSON.stringify({ ok: false, error: chk.msg })).setMimeType(ContentService.MimeType.JSON);
      }

      let body = {};
      try {
        body = e.postData && e.postData.contents ? JSON.parse(e.postData.contents) : {};
      } catch (err) {
        return ContentService.createTextOutput(JSON.stringify({ ok: false, error: 'Invalid JSON' })).setMimeType(ContentService.MimeType.JSON);
      }

      const result = cd_receiveResults_(body);
      return ContentService.createTextOutput(JSON.stringify(result)).setMimeType(ContentService.MimeType.JSON);
    }

    // Regular donor matching
    const chk = dl_validateToken_(p.token);
    if (!chk.ok) {
      return ContentService.createTextOutput(JSON.stringify({ ok: false, error: chk.msg })).setMimeType(ContentService.MimeType.JSON);
    }

    let body = {};
    try {
      body = e.postData && e.postData.contents ? JSON.parse(e.postData.contents) : {};
    } catch (err) {
      return ContentService.createTextOutput(JSON.stringify({ ok: false, error: 'Invalid JSON' })).setMimeType(ContentService.MimeType.JSON);
    }

    const responseData = { ok: true };

      if (body.progress) {
        dl_setProgress_(String(body.progress.phase || ''), Number(body.progress.done || 0), Number(body.progress.total || 0), String(body.progress.note || ''));
      }

      if (Array.isArray(body.training_rows) && body.training_rows.length) {
        donor_applyResult_trainingRows_(body.training_rows);
        responseData.training_saved = body.training_rows.length;
      }

      if (Array.isArray(body.model_weights) && body.model_weights.length) {
        donor_applyResult_modelWeights_(body.model_weights);
        responseData.weights_saved = body.model_weights.length;
      }

      if (Array.isArray(body.blocking_rules) && body.blocking_rules.length) {
        donor_applyResult_blockingRules_(body.blocking_rules);
        responseData.blocking_rules_saved = body.blocking_rules.length;
      }

      if (body.id_map && typeof body.id_map === 'object') {
        donor_applyResult_assignedIds_(body.id_map);
      }

      // Handle new merge_rows format (Python builds complete rows)
      if (Array.isArray(body.merge_rows) && body.merge_rows.length) {
        const batchSize = body.merge_rows.length;
        const batchIndex = typeof body.batch_index === 'number' ? body.batch_index : -1;
        Logger.log('Received batch ' + batchIndex + ' with ' + batchSize + ' merge rows');

        const ss = SpreadsheetApp.getActive();
        const mergeSheet = donor_getOrCreateSheet_('Merge output');

        // Define output header
        const outputHeader = [
          'Recipient', 'DonorFirst', 'DonorLast', 'Address1', 'Address2',
          'City', 'State', 'Zip', 'Amount', 'WeightedAmount', 'ReceiptDate',
          'Occupation', 'Employer', 'DonationID', 'DonorID', 'Confidence'
        ];

        // Clear sheet on first batch of new run
        const isFirstBatch = batchIndex === 0;

        if (isFirstBatch) {
          // Clear all data rows (row 2 and below), preserve header if it exists
          const lastRow = mergeSheet.getLastRow();
          if (lastRow > 1) {
            mergeSheet.deleteRows(2, lastRow - 1);
            Logger.log('Cleared data rows (2-' + lastRow + ') from Merge output sheet');
          }

          // Ensure header exists and is formatted
          const hasHeader = mergeSheet.getLastRow() >= 1 && mergeSheet.getRange(1, 1).getValue() !== '';
          if (!hasHeader) {
            mergeSheet.getRange(1, 1, 1, outputHeader.length).setValues([outputHeader]);
            Logger.log('Created header row');
          }

          // Format header
          mergeSheet.getRange(1, 1, 1, outputHeader.length)
            .setFontWeight('bold')
            .setBackground('#4285f4')
            .setFontColor('#ffffff');
          mergeSheet.setFrozenRows(1);
          Logger.log('Prepared Merge output sheet for new run');
        }

        // Append rows to Merge output
        const startRow = mergeSheet.getLastRow() + 1;
        mergeSheet.getRange(startRow, 1, body.merge_rows.length, outputHeader.length)
          .setValues(body.merge_rows);

        const totalRows = mergeSheet.getLastRow() - 1; // Exclude header
        Logger.log('Wrote ' + batchSize + ' rows. Total in sheet: ' + totalRows);

        // Unhide all rows and columns to ensure data is visible
        if (mergeSheet.getMaxRows() > 0) {
          mergeSheet.showRows(1, mergeSheet.getMaxRows());
        }
        if (mergeSheet.getMaxColumns() > 0) {
          mergeSheet.showColumns(1, mergeSheet.getMaxColumns());
        }

        responseData.merge_output = {
          success: true,
          rows_in_batch: batchSize,
          total_rows: totalRows,
          batch_index: batchIndex,
          message: 'Batch written to Merge output'
        };
      }

    return ContentService.createTextOutput(JSON.stringify(responseData)).setMimeType(ContentService.MimeType.JSON);
  } catch (err) {
    const message = (err && err.message) ? err.message : String(err);
    Logger.log('doPost error: ' + message + '\n' + (err && err.stack ? err.stack : ''));
    return ContentService.createTextOutput(JSON.stringify({ ok: false, error: message })).setMimeType(ContentService.MimeType.JSON);
  }
}
