/**
 * Processes uploaded merge output CSV and writes it to Merge output sheet.
 * @param {string} csvContent - Merge output CSV contents
 * @param {string} fileName - Original filename
 * @returns {Object} Result with success status and message
 */
function cd_processMergeOutputUpload(csvContent, fileName) {
  try {
    const rows = Utilities.parseCsv(csvContent);
    if (rows.length === 0) {
      throw new Error('CSV file is empty');
    }

    const expectedHeader = [
      'Recipient', 'DonorFirst', 'DonorLast', 'Address1', 'Address2',
      'City', 'State', 'Zip', 'Amount', 'WeightedAmount', 'ReceiptDate',
      'Occupation', 'Employer', 'DonationID', 'DonorID', 'Confidence'
    ];

    const uploadedHeader = rows[0].map(v => String(v || '').trim());
    const missingHeaderCols = expectedHeader.filter(col => !uploadedHeader.includes(col));
    if (missingHeaderCols.length > 0) {
      throw new Error('Missing required columns: ' + missingHeaderCols.join(', '));
    }

    const ss = SpreadsheetApp.getActive();
    let sheet = ss.getSheetByName('Merge output');
    if (!sheet) {
      sheet = ss.insertSheet('Merge output');
    } else {
      sheet.clear();
    }

    sheet.getRange(1, 1, rows.length, rows[0].length).setValues(rows);

    const headerRange = sheet.getRange(1, 1, 1, rows[0].length);
    headerRange.setFontWeight('bold');
    headerRange.setBackground('#4285f4');
    headerRange.setFontColor('#ffffff');
    sheet.setFrozenRows(1);

    for (let i = 1; i <= rows[0].length; i++) {
      sheet.autoResizeColumn(i);
    }

    Logger.log('Merge output uploaded: ' + fileName + ' (' + rows.length + ' rows)');
    return {
      success: true,
      message: 'Successfully imported ' + fileName + ' into Merge output',
      rowCount: Math.max(0, rows.length - 1)
